# Copy this file to `.env` and fill in your values.
# Apollo API key (required). Get it from Apollo > Settings > Integrations > API.
APOLLO_API_KEY=your_apollo_api_key_here

# Mailbox to send from. Must already be connected in Apollo.
APOLLO_SEND_FROM_EMAIL=sneshkakkar11@gmail.com

# Daily send cap per mailbox (deliverability guardrail).
DAILY_EMAIL_LIMIT=30
